<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InfoMedicamento">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="629dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="1dp">

            <ImageView
                android:layout_width="216dp"
                android:layout_height="100dp"
                android:contentDescription="Logo"
                android:src="@drawable/ic_logo"
                android:layout_weight="1" />

            <View
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/textToolbarLogin"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="Login"
                android:textColor="#000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_weight="1" />

        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="409dp"
        android:layout_height="625dp"
        android:layout_marginTop="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Dipirona"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/lnrLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/txtView6"
                    android:layout_width="238dp"
                    android:layout_height="201dp"
                    android:layout_marginStart="9dp"
                    android:layout_marginEnd="9dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center"
                    android:text="DESCRIÇÃO: A dipirona é um medicamento utilizado para aliviar a dor de cabeça de forma muito eficiente, inibindo a produção de substâncias, como a prostaglandina, que causa o desconforto físico. É um anti-inflamatório que também age como analgésico. Seu nome químico é Matamizol. É vendido sob marcas como Novalgina e Neosaldina e Genéricos dos mais variados laboratórios em todas as regiões do Brasil."
                    android:textColor="#444444"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/imgview"
                    android:layout_width="162dp"
                    android:layout_height="168dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/fundo_verde" />

                <ImageView
                    android:id="@+id/imageView3"
                    android:layout_width="118dp"
                    android:layout_height="124dp"
                    android:layout_marginStart="25dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="19dp"
                    android:layout_marginBottom="20dp"
                    app:layout_constraintBottom_toBottomOf="@+id/imgview"
                    app:layout_constraintEnd_toEndOf="@+id/imgview"
                    app:layout_constraintStart_toStartOf="@+id/imgview"
                    app:layout_constraintTop_toTopOf="@+id/imgview"
                    app:srcCompat="@drawable/dipirona" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/linearLayout4"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/txtView5"
                    android:layout_width="238dp"
                    android:layout_height="201dp"
                    android:layout_marginStart="9dp"
                    android:layout_marginEnd="9dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center"
                    android:text="ESPECIFICAÇÕES: Princípio ativo: Derivado pirazolônico não narcótico com efeitos antipirético. Forma de administração: Oral, endovenosa, intra-muscular, parenteral ou retal. Prescrição médica: Para adultos e adolescentes acima de 15 anos, a dose recomendada é de meio a 1 comprimido, administrado até 4 vezes por dia. Tipo de medicamento: Analgésico e antitérmico"
                    android:textColor="#444444"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/imgView3"
                    android:layout_width="162dp"
                    android:layout_height="168dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="13dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/txtView5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/fundo_verde" />

                <ImageView
                    android:id="@+id/imageView9"
                    android:layout_width="158dp"
                    android:layout_height="127dp"
                    android:layout_marginTop="21dp"
                    android:layout_marginBottom="20dp"
                    app:layout_constraintBottom_toBottomOf="@+id/imgView3"
                    app:layout_constraintEnd_toEndOf="@+id/imgView3"
                    app:layout_constraintStart_toStartOf="@+id/imgView3"
                    app:layout_constraintTop_toTopOf="@+id/imgView3"
                    app:srcCompat="@drawable/sintomas_dipirona" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="97dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="135dp"
                    android:layout_height="match_parent"
                    android:background="#9FE9A1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView12"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:background="#58A77E"
                        android:gravity="center"
                        android:text="Vendido por:"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/drogaria1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Drogaria 1"
                        android:textAlignment="center" />

                    <TextView
                        android:id="@+id/drogaria2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Drogaria 2"
                        android:textAlignment="center" />

                    <TextView
                        android:id="@+id/drogaria3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Drogaria 3"
                        android:textAlignment="center" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="135dp"
                    android:layout_height="match_parent"
                    android:background="#9FE9A1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView16"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:background="#58A77E"
                        android:gravity="center"
                        android:text="Preço:"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/precoDrog1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="R$XX,XX"
                        android:textAlignment="center" />

                    <TextView
                        android:id="@+id/precoDrog2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="R$XX,XX"
                        android:textAlignment="center" />

                    <TextView
                        android:id="@+id/precoDrog3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="R$XX,XX"
                        android:textAlignment="center" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="135dp"
                    android:layout_height="match_parent"
                    android:background="#9FE9A1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView23"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:background="#58A77E"
                        android:gravity="center"
                        android:text="Compre:"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/linkDrog1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Acesse aqui"
                        android:textAlignment="center"
                        android:textColor="#2196F3" />

                    <TextView
                        android:id="@+id/linkDrog2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Acesse aqui"
                        android:textAlignment="center"
                        android:textColor="#2196F3" />

                    <TextView
                        android:id="@+id/linkDrog3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Acesse aqui"
                        android:textAlignment="center"
                        android:textColor="#2196F3" />
                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoltar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="15dp"
                android:backgroundTint="#888888"
                android:text="Voltar"
                android:textColor="#FFFFFF"
                app:cornerRadius="32dp"
                app:elevation="2dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>